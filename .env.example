# Database Configuration
DATABASE_URL="postgresql://pgqiospay:pgqiospay_secret@localhost:5432/pgqiospay?schema=public"

# JWT Secret (change this in production!)
JWT_SECRET="change-this-to-a-secure-random-string-in-production"

# Webhook Secret for X-Signature validation
WEBHOOK_SECRET="change-this-webhook-secret-in-production"

# Allowed IPs for webhook callbacks (comma-separated, supports CIDR)
ALLOWED_WEBHOOK_IPS="103.56.148.0/24,103.56.149.0/24"

# Application Name
NEXT_PUBLIC_APP_NAME="QRIS Payment Gateway"

# Socket Configuration (for devsock deployment)
SOCKET_PATH="/tmp/nextjs-payment.sock"
USE_SOCKET="false"
